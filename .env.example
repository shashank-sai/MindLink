# MindLink Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: This is a TEMPLATE - replace placeholder values with your own

# ===========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://mindlink_user:your_password@localhost:5432/MindLink
DB_HOST=localhost
DB_PORT=5432
DB_NAME=MindLink
DB_USER=mindlink_user
DB_PASSWORD=your_password

# ===========================================
# VECTOR DATABASE (ChromaDB)
# ===========================================
CHROMA_DB_PATH=./chroma_db
# OR for remote ChromaDB:
# CHROMA_DB_HOST=localhost
# CHROMA_DB_PORT=8000

# ===========================================
# SECURITY (JWT & Passwords)
# ===========================================
# Generate a strong random secret for JWT
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=generate_a_strong_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===========================================
# OLLAMA CONFIGURATION
# ===========================================
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# ===========================================
# APP SETTINGS
# ===========================================
FLASK_SECRET_KEY=another_random_secret_for_flask
DEBUG=False
LOG_LEVEL=INFO

# ===========================================
# MODEL CONFIGURATION
# ===========================================
THERAPIST_MODEL=phi3:3.8b
SENTINEL_MODEL=mistral:7b
SYNTHESIS_MODEL=phi3.5:3.8b
